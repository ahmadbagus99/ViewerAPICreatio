VIEWER_PORT=5003
VIEWER_PUBLIC_URL=http://localhost:5003
VIEWER_ADMIN_USERNAME=admin
VIEWER_ADMIN_PASSWORD=change-this-admin-password
VIEWER_SESSION_SECRET=replace-with-a-long-random-secret
VIEWER_COOKIE_SECURE=false

# ── Database ─────────────────────────────────────────────────────────────────
# Opsi A: biarkan kosong, postgres container akan dijalankan otomatis
# Opsi B: pakai DATABASE_URL langsung untuk koneksi ke database eksternal
#          Jika DATABASE_URL diisi, variabel POSTGRES_* tidak diperlukan
# DATABASE_URL=postgresql://user:password@host.docker.internal:5433/dbname
#
# Opsi C: pakai POSTGRES_HOST/PORT untuk shared postgres yang sudah jalan
# POSTGRES_HOST=host.docker.internal
# POSTGRES_PORT=5433

POSTGRES_DB=creatio_viewer
POSTGRES_USER=creatio_user
POSTGRES_PASSWORD=change-this-db-password
